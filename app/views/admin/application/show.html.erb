
<%# Template customizado para exibir detalhes de um recurso com layout de grid. %>


<style>
  /* 1. AJUSTE DO CABEÇALHO E BOTÕES DE AÇÃO */
  .main-content__header {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    margin-bottom: 2rem !important;
    flex-wrap: nowrap !important;
  }

  .main-content__header h1 { 
    margin: 0 !important; 
    font-size: 1.8rem !important; 
  }

  /* Container dos botões editar e excluir */
  .main-content__header > div:last-child {
    display: flex !important;
    gap: 12px !important;
    align-items: center !important;
  }

  /* Botão Editar/
  .main-content__header a.button {
    background: #2F4550 !important;
    color: white !important;
    padding: 12px 24px !important;
    border-radius: 12px !important;
    font-weight: 600 !important;
    text-decoration: none !important;
    border: none !important;
  }

  /* Botão Excluir */
  .main-content__header .button--danger, 
  .main-content__header form button,
  .main-content__header input[type="submit"] {
    background: #FEE2E2 !important;
    color: #EF4444 !important;
    border: 1px solid #FCA5A5 !important;
    padding: 12px 24px !important;
    border-radius: 12px !important;
    font-weight: 600 !important;
    cursor: pointer !important;
    margin: 0 !important;
  }

  /* 2. CONTAINER DE DADOS (Card Principal) */
  .main-content__body {
    background: white !important;
    border: 1px solid #E2E8F0 !important;
    border-radius: 16px !important;
    overflow: hidden !important;
    padding: 0 !important;
  }

  fieldset {
    border: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Estilo das legendas de seção dentro do card */
  legend {
    display: block !important;
    width: 100% !important;
    padding: 15px 20px !important;
    background: #F1F5F9 !important;
    color: #586F7C !important;
    font-weight: bold !important;
    text-transform: uppercase !important;
    font-size: 0.8rem !important;
  }

  /* 3. GRID DE INFORMAÇÕES (Tabela de Atributos) */
  
  dl {
    display: grid !important;
    grid-template-columns: 240px 1fr !important; 
    margin: 0 !important;
  }

  
  dt.attribute-label {
    grid-column: 1 !important;
    background: #F8FAFC !important;
    color: #586F7C !important;
    padding: 20px !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    font-size: 0.75rem !important;
    letter-spacing: 0.05em !important;
    border-bottom: 1px solid #F1F5F9 !important;
    border-right: 1px solid #F1F5F9 !important;
    margin: 0 !important;
  }

  
  dd.attribute-data {
    grid-column: 2 !important;
    padding: 20px !important;
    color: #2F4550 !important;
    font-weight: 500 !important;
    border-bottom: 1px solid #F1F5F9 !important;
    margin: 0 !important;
  }

  
  dt.attribute-label:last-of-type,
  dd.attribute-data:last-of-type {
    border-bottom: none !important;
  }
</style>

<%# Título da Página definido dinamicamente pelo Rails %>
<% content_for(:title) { t("administrate.actions.show_resource", name: page.page_title) } %>

<header class="main-content__header">
  <h1 class="main-content__page-title">
    <%= content_for(:title) %>
  </h1>

  <%= content_for(:header_middle) %>

  <div>
    <%# Botão de Edição - Só aparece se o usuário tiver permissão %>
    <%= link_to(
      t("administrate.actions.edit_resource", name: page.page_title),
      [:edit, namespace, page.resource],
      class: "button",
    ) if accessible_action?(page.resource, :edit) %>

    <%# Botão de Exclusão - Inclui confirmação para segurança dos dados %>
    <%= button_to(
      t("administrate.actions.destroy"),
      [namespace, page.resource],
      class: "button button--danger",
      method: :delete,
      data: { turbo_confirm: t("administrate.actions.confirm") }
    ) if accessible_action?(page.resource, :destroy) %>
  </div>

  <%= content_for(:header_last) %>
</header>

<%= content_for(:before_main) %>

<%# Início da renderização dos dados do registro %>
<% if content_for?(:main) %>
  <%= content_for(:main) %>
<% else %>
  <section class="main-content__body">
    <dl>
      <%# Itera sobre os atributos definidos no Dashboard do Administrate %>
      <% page.attributes.each do |title, attributes| %>
        
        <%# Cabeçalho de seção (Título agrupador, se houver) %>
        <% if title.present? %>
          <div style="grid-column: 1 / -1; background: #F1F5F9; padding: 12px 20px; font-weight: bold; color: #586F7C; border-bottom: 1px solid #E2E8F0;">
            <%= t "helpers.label.#{page.resource_name}.#{title}", default: title %>
          </div>
        <% end %>

        <%# Renderização do par Rótulo e Valor %>
        <% attributes.each do |attribute| %>
          <dt class="attribute-label" id="<%= attribute.name %>">
            <%# Busca a tradução do nome do campo no arquivo i18n %>
            <%= t(
              "helpers.label.#{resource_name}.#{attribute.name}",
              default: page.resource.class.human_attribute_name(attribute.name),
            ) %>
          </dt>

          <dd class="attribute-data attribute-data--<%=attribute.html_class%>">
            <%# Chama o componente de renderização específico para o tipo de dado (texto, data, booleano) %>
            <%= render_field attribute, page: page %>
          </dd>
        <% end %>
      <% end %>
    </dl>
  </section>
<% end %>

<%= content_for(:after_main) %>